---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLoader from '../components/PageLoader.astro';
import Navbar from '../components/Navbar.astro';
import AIVibeBanner from '../components/AIVibeBanner.astro';
import HeroSection from '../components/HeroSection.astro';
import FeaturesScroll from '../components/FeaturesScroll.astro';
import MarketView from '../components/MarketView.astro';
import DocsView from '../components/DocsView.astro';
import AboutView from '../components/AboutView.astro';
import SettingsView from '../components/SettingsView.astro';
import Modals from '../components/Modals.astro';
import Footer from '../components/Footer.astro';

// 这是 SPA 风格的兜底页面。
// GitHub Pages 在找不到对应静态文件时会返回 404.html，
// 因此我们在这里包含所有视图容器，并让客户端路由
// （main.js 的 switchViewByPath / navigateToDocument）
// 根据 window.location.pathname 渲染正确的视图，
// 从而解决「直接访问路由返回 404，但从首页点进去正常」的问题。
---

<BaseLayout activeView="home" title="ErisPulse - 异步机器人开发框架">
  <PageLoader />
  <Navbar activeView="home" />

  <main class="main-content">
    <!-- 首页视图 -->
    <div id="home-view" class="view-container active">
      <AIVibeBanner />
      <HeroSection />
      <FeaturesScroll />
    </div>

    <!-- 其它视图容器，供客户端路由按路径激活 -->
    <MarketView activeView="home" />
    <DocsView activeView="home" />
    <AboutView activeView="home" />
    <SettingsView activeView="home" />

    <Modals />
  </main>

  <Footer />
</BaseLayout>
