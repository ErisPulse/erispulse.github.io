---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLoader from '../components/PageLoader.astro';
import Navbar from '../components/Navbar.astro';
import AIVibeBanner from '../components/AIVibeBanner.astro';
import HeroSection from '../components/HeroSection.astro';
import FeaturesScroll from '../components/FeaturesScroll.astro';
import Modals from '../components/Modals.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout activeView="home" title="ErisPulse - 异步机器人开发框架">
  <PageLoader />
  <Navbar activeView="home" />
  
  <main class="main-content">
    <!-- 首页视图 -->
    <div id="home-view" class="view-container active">
      <AIVibeBanner />
      <HeroSection />
      <FeaturesScroll />
    </div>

    <Modals />
  </main>

  <Footer />
</BaseLayout>
