---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLoader from '../components/PageLoader.astro';
import Navbar from '../components/Navbar.astro';
import MarketView from '../components/MarketView.astro';
import Modals from '../components/Modals.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout activeView="market" title="模块市场 - ErisPulse">
  <PageLoader />
  <Navbar activeView="market" />
  
  <main class="main-content">
    <MarketView activeView="market" />
    <Modals />
  </main>

  <Footer />
</BaseLayout>
