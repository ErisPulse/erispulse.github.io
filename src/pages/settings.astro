---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLoader from '../components/PageLoader.astro';
import Navbar from '../components/Navbar.astro';
import SettingsView from '../components/SettingsView.astro';
import Modals from '../components/Modals.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout activeView="settings" title="个性化设置 - ErisPulse">
  <PageLoader />
  <Navbar activeView="settings" />
  
  <main class="main-content">
    <SettingsView activeView="settings" />
    <Modals />
  </main>

  <Footer />
</BaseLayout>
