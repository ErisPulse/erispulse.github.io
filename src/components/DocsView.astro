---
export interface Props {
  activeView?: string;
}

const { activeView = 'home' } = Astro.props;
---
<div id="docs-view" class={`view-container ${activeView === 'docs' ? 'active' : ''}`}>
  <div class="container">
    <div class="docs-layout">
      <!-- 左侧导航栏 -->
      <aside class="docs-sidebar">
        <div class="docs-sidebar-header">
          <!-- 语言切换器 -->
          <div class="docs-language-switcher">
            <div class="lang-select-wrapper">
              <select id="lang-select" class="lang-select">
                <option value="zh-CN" selected>简体中文</option>
                <option value="en">English</option>
                <option value="zh-TW">繁體中文</option>
                <option value="ja">日本語</option>
                <option value="ru">Русский</option>
              </select>
            </div>
          </div>
        </div>
        <div class="docs-nav-container">
          <!-- 文档导航将通过JavaScript动态生成 -->
        </div>
      </aside>

      <!-- 主内容区域 -->
      <main class="docs-main">
        <!-- 面包屑导航 -->
        <nav class="docs-breadcrumb">
          <a href="/docs" data-i18n="docs.title">文档中心</a>
          <span class="separator">/</span>
          <span class="current" data-i18n="docs.welcome">欢迎使用</span>
        </nav>

        <!-- 文档操作栏 -->
        <div class="docs-actions">
          <a href="#" class="docs-action-btn">
            <i class="fas fa-edit"></i>
            <span data-i18n="docs.edit">编辑此页</span>
          </a>
          <a href="#" class="docs-action-btn">
            <i class="fas fa-share-alt"></i>
            <span data-i18n="docs.share">分享</span>
          </a>
        </div>

        <!-- 文档内容 -->
        <div class="markdown-content" id="docs-content">
          <div>
            <h1 data-i18n="docs.welcome">欢迎使用 ErisPulse</h1>
            <p data-i18n="docs.welcome.desc">ErisPulse 是一个开源的 Python 库，目标是提供一个简单、易于使用的框架，用于构建异步、非阻塞的机器人程序。</p>
            <p data-i18n="docs.welcome.hint">点击文档导航中的链接，开始探索 ErisPulse 的功能和用法吧。</p>
          </div>
        </div>
      </main>
    </div>
  </div>
</div>

<script>
  import Chart from 'chart.js/auto';
  import mermaid from 'mermaid';

  window.Chart = Chart;
  window.mermaid = mermaid;
</script>
