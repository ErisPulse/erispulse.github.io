---
import HeroCanvasIsland from './HeroCanvasIsland.astro';
---
<section class="hero-section">
  <HeroCanvasIsland />
  <div class="hero-content">
    <h1 class="hero-title">ErisPulse</h1>
    <p class="hero-subtitle" data-i18n="hero.subtitle">事件驱动 · 多平台 · 一个框架搞定一切</p>
    <div class="hero-actions" id="hero-actions">
      <button class="btn btn-primary hero-start-btn" id="hero-start-btn">
        <i class="fas fa-rocket"></i> <span data-i18n="hero.start">开始使用</span>
      </button>
      <div class="hero-actions-expanded" id="hero-actions-expanded">
        <a href="#" class="btn hero-btn-ghost" data-view="docs">
          <i class="fas fa-book"></i> <span data-i18n="hero.docs">文档中心</span>
        </a>
        <a href="#" class="btn hero-btn-install" id="hero-install-btn">
          <i class="fas fa-terminal"></i> <span data-i18n="install.btn">立即安装</span>
        </a>
        <a href="#" class="btn hero-btn-ghost" data-view="market">
          <i class="fas fa-box-open"></i> <span data-i18n="hero.browse">模块市场</span>
        </a>
      </div>
    </div>
  </div>
  <div class="scroll-indicator">
    <i class="fas fa-chevron-down"></i>
  </div>
</section>

<!-- Install Overlay -->
<div class="hero-install-overlay" id="hero-install-overlay">
  <div class="hero-install-backdrop"></div>
  <div class="hero-install-panel">
    <button class="install-overlay-close" id="install-overlay-close">
      <i class="fas fa-times"></i>
    </button>
    <h3 class="install-overlay-title" data-i18n="install.title">一键安装</h3>
    <p class="install-overlay-desc" data-i18n="install.desc">自动检测环境，引导选择最适合的安装方式</p>
    <div class="install-platform-tabs">
      <button class="install-tab active" data-platform="windows">
        <i class="fab fa-windows"></i> <span>Windows</span>
      </button>
      <button class="install-tab" data-platform="unix">
        <i class="fab fa-linux"></i> <span>macOS / Linux</span>
      </button>
    </div>
    <div class="install-code-block">
      <span class="install-code-prefix" id="install-code-prefix">PS&gt;</span>
      <code class="install-code-text" id="install-code-text"></code>
      <button class="install-copy-btn" id="install-copy-btn" title="Copy">
        <i class="fas fa-copy" id="install-copy-icon"></i>
      </button>
    </div>
    <p class="install-hint" data-i18n="install.hint">支持 Docker、Python、uv 等多种安装方式</p>
  </div>
</div>
