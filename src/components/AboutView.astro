---
export interface Props {
  activeView?: string;
}

const { activeView = 'home' } = Astro.props;
---
<div id="about-view" class={`view-container ${activeView === 'about' ? 'active' : ''}`}>
  <div class="container">
    <section class="contributors">
      <h2 class="section-title">
        <span data-i18n="about.contributors">我们的贡献者</span>
        <span id="contributors-count">--</span>
      </h2>
      <p class="section-subtitle" data-i18n="about.contributorsDesc">感谢这些优秀的开发者为项目做出的贡献</p>

      <div class="contributors-grid" id="contributors-container">
        <!-- 贡献者卡片将通过JS动态生成 -->
      </div>

      <!-- 友情链接区域 -->
      <div class="friend-links-section">
        <h2 class="section-title" data-i18n="about.friendLinks">友情链接</h2>
        <p class="section-subtitle" data-i18n="about.friendLinksDesc">推荐一些优秀的技术和开发资源</p>
        <div class="friend-links-grid" id="friend-links-container">
          <!-- 友情链接将通过JS动态生成 -->
        </div>
      </div>

      <div class="copyright-section">
        <div class="copyright-content">
          <h3 class="copyright-title" data-i18n="about.copyright">版权声明</h3>
          <p data-i18n="about.copyrightText">ErisPulse 使用 MIT 开源协议，允许自由分发和修改。</p>
        </div>
      </div>
    </section>
  </div>
</div>
